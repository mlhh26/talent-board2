<!DOCTYPE html>
<html lang="en">

<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Health Hub Talent Board</title>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

<style>

:root{

--orange:#FF6B00;
--orange-dark:#E55F00;
--orange-light:#FFF4EA;

--text:#1B1B1B;
--text-light:#666;

--border:#ECECEC;
--background:#FAFAFA;

--shadow:
0 10px 30px rgba(0,0,0,.05);

}

*{
margin:0;
padding:0;
box-sizing:border-box;
}

body{

font-family:'Inter',sans-serif;
background:var(--background);
color:var(--text);

}

a{
text-decoration:none;
}

img{
max-width:100%;
display:block;
}

.container{

width:min(1200px,92%);
margin:auto;

}

/* =====================
HEADER
===================== */

header{

background:white;
border-bottom:1px solid var(--border);

position:sticky;
top:0;
z-index:999;

}

.header-inner{

display:flex;
justify-content:space-between;
align-items:center;

padding:20px 0;

}

.logo{

display:flex;
align-items:center;
gap:16px;

}

.logo img{

height:65px;
width:auto;

}

.post-job{

background:var(--orange);
color:white;

padding:14px 22px;

border-radius:12px;

font-weight:600;

transition:.2s;

}

.post-job:hover{

background:var(--orange-dark);

}

/* =====================
HERO
===================== */

.hero{

background:white;

padding:90px 0;

text-align:center;

}

.hero h1{

font-size:clamp(40px,6vw,72px);

line-height:1.05;

font-weight:800;

max-width:900px;

margin:auto;

}

.hero h1 span{

color:var(--orange);

}

.hero p{

margin-top:25px;

font-size:20px;

color:var(--text-light);

max-width:700px;

margin-left:auto;
margin-right:auto;

}

.search-wrapper{

margin-top:45px;

display:flex;
justify-content:center;

}

.search-box{

background:white;

width:min(760px,100%);

display:flex;

border:1px solid var(--border);

border-radius:18px;

overflow:hidden;

box-shadow:var(--shadow);

}

.search-box input{

flex:1;

border:none;

padding:22px;

font-size:16px;

outline:none;

}

.search-btn{

background:var(--orange);

border:none;

color:white;

padding:0 30px;

font-size:16px;

font-weight:600;

cursor:pointer;

}

/* =====================
RESULTS
===================== */

.results-section{

padding:60px 0;

}

.results-header{

display:flex;
justify-content:space-between;
align-items:center;

margin-bottom:30px;

gap:20px;

flex-wrap:wrap;

}

.results-title{

font-size:34px;
font-weight:800;

}

.results-count{

color:var(--text-light);

margin-top:8px;

}

/* =====================
FILTERS
===================== */

.filters{

display:flex;
gap:12px;

flex-wrap:wrap;

}

.filter-btn{

background:white;

border:1px solid var(--border);

padding:10px 18px;

border-radius:999px;

cursor:pointer;

font-size:14px;

transition:.2s;

}

.filter-btn:hover{

border-color:var(--orange);

color:var(--orange);

}

.filter-btn.active{

background:var(--orange);

color:white;

border-color:var(--orange);

}

/* =====================
JOB LIST
===================== */

.job-list{

display:flex;
flex-direction:column;
gap:22px;

}

.job-card{

background:white;

border:1px solid var(--border);

border-radius:20px;

padding:28px;

box-shadow:var(--shadow);

transition:.25s;

}

.job-card:hover{

transform:translateY(-3px);

}

.job-top{

display:flex;
justify-content:space-between;
align-items:flex-start;
gap:20px;

}

.job-title{

font-size:28px;
font-weight:700;

margin-bottom:10px;

}

.job-location{

color:var(--text-light);

font-size:15px;

}

.job-tags{

display:flex;
gap:10px;
flex-wrap:wrap;

margin-top:18px;

}

.tag{

background:var(--orange-light);

color:var(--orange-dark);

padding:8px 14px;

border-radius:999px;

font-size:13px;

font-weight:600;

}

.job-description{

margin-top:22px;

line-height:1.7;

color:#444;

}

.job-footer{

margin-top:24px;

display:flex;

justify-content:space-between;

align-items:center;

gap:20px;

flex-wrap:wrap;

}

.salary{

font-size:20px;
font-weight:700;

}

.apply-btn{

background:var(--orange);

color:white;

padding:14px 22px;

border-radius:12px;

font-weight:600;

}

.apply-btn:hover{

background:var(--orange-dark);

}

.loading{

text-align:center;

padding:80px;

font-size:18px;

}

/* =====================
MOBILE
===================== */

@media(max-width:768px){

.hero{

padding:60px 0;

}

.hero p{

font-size:17px;

}

.logo img{

height:48px;

}

.job-title{

font-size:22px;

}

.search-btn{

display:none;

}

}

</style>

</head>

<body>

<header>

<div class="container header-inner">

<div class="logo">

<img src="logo.png" alt="Health Hub">

</div>

<a
class="post-job"
target="_blank"
href="https://docs.google.com/forms">

Post a Job

</a>

</div>

</header>
<!-- =====================
HERO
===================== -->

<section class="hero">

<div class="container">

<h1>
Find your next opportunity in
<span>Health Innovation</span>
</h1>

<p>
Connecting talent with leading healthtech companies across
Barcelona, Madrid and Málaga.
</p>

<div class="search-wrapper">

<div class="search-box">

<input
type="text"
id="searchInput"
placeholder="Search jobs, locations or keywords...">

<button class="search-btn">

Search

</button>

</div>

</div>

</div>

</section>

<!-- =====================
RESULTS
===================== -->

<section class="results-section">

<div class="container">

<div class="results-header">

<div>

<h2 class="results-title">

Open Positions

</h2>

<div
class="results-count"
id="resultsCount">

Loading jobs...

</div>

</div>

<div class="filters">

<button
class="filter-btn active"
data-filter="all">

All

</button>

<button
class="filter-btn"
data-filter="Full-time">

Full-time

</button>

<button
class="filter-btn"
data-filter="Part-time">

Part-time

</button>

<button
class="filter-btn"
data-filter="Contract">

Contract

</button>

<button
class="filter-btn"
data-filter="Remote">

Remote

</button>

<button
class="filter-btn"
data-filter="Hybrid">

Hybrid

</button>

<button
class="filter-btn"
data-filter="On-site">

On-site

</button>

</div>

</div>

<!-- JOB LIST -->

<div
class="job-list"
id="jobList">

<div class="loading">

Loading opportunities...

</div>

</div>

</div>

</section>

<!-- =====================
FOOTER
===================== -->

<footer
style="
background:white;
border-top:1px solid #ececec;
padding:50px 0;
margin-top:60px;
">

<div
class="container"
style="
display:flex;
justify-content:space-between;
align-items:center;
gap:20px;
flex-wrap:wrap;
">

<div>

<img
src="logo.png"
style="height:50px; width:auto;">

</div>

<div
style="
color:#666;
font-size:14px;
">

Connecting innovation, health and talent.

</div>

</div>

</footer>
<script>

const SHEET_ID =
"1pEzAFcI1Mfk9mnokDQ08TU3EllXq3o5kJ_SrBqIfLVs";

let allJobs = [];
let currentFilter = "all";

/* =====================
LOAD DATA
===================== */

async function loadJobs(){

try{

const response = await fetch(
`https://docs.google.com/spreadsheets/d/${SHEET_ID}/gviz/tq?tqx=out:json`
);

const text = await response.text();

const json = JSON.parse(
text.substring(47).slice(0,-2)
);

/* IMPORTANT:
READ COLUMN NAMES DIRECTLY
FROM GOOGLE SHEETS
*/

const headers =
json.table.cols.map(col => col.label);

const rows =
json.table.rows;

allJobs = rows.map(row => {

const job = {};

headers.forEach((header,index)=>{

job[header] =
row.c[index]?.v || "";

});

return job;

});

renderJobs(allJobs);

}catch(error){

console.error(error);

document.getElementById("jobList").innerHTML = `
<div class="job-card">
<h3>Unable to load jobs</h3>
<p>Please check that the Google Sheet is public.</p>
</div>
`;

}

}

/* =====================
RENDER
===================== */

function renderJobs(jobs){

document.getElementById("resultsCount")
.innerHTML = `${jobs.length} opportunities available`;

const container =
document.getElementById("jobList");

if(jobs.length === 0){

container.innerHTML = `
<div class="job-card">
<h3>No jobs found</h3>
<p>Try another search.</p>
</div>
`;

return;

}

container.innerHTML = jobs.map(job => `

<div class="job-card">

<div class="job-top">

<div>

<div class="job-title">
${job["Job Title"] || "Untitled"}
</div>

<div class="job-location">

📍 ${job["Location"] || ""}

</div>

</div>

</div>

<div class="job-tags">

${job["Employment Type"] ?
`<div class="tag">${job["Employment Type"]}</div>`
: ''}

${job["Work Location Model"] ?
`<div class="tag">${job["Work Location Model"]}</div>`
: ''}

${job["Years of Experience Required"] ?
`<div class="tag">${job["Years of Experience Required"]}</div>`
: ''}

</div>

<div class="job-description">

${job["Job Description"] || ""}

</div>

<div style="
margin-top:20px;
font-size:14px;
line-height:1.6;
color:#555;
">

<strong>Required Skills:</strong><br>

${job["Required Skills and Qualifications"] || ""}

</div>

<div class="job-footer">

<div>

<div class="salary">

${job["Salary Range (Annual)"] || "Salary undisclosed"}

</div>

<div style="
font-size:14px;
color:#666;
margin-top:6px;
">

Deadline:
${job["Application Deadline"] || "Open"}

</div>

</div>

<a
class="apply-btn"
target="_blank"
href="${job["Application link"] || '#'}">

Apply Now

</a>

</div>

</div>

`).join("");

}

/* =====================
SEARCH
===================== */

document
.getElementById("searchInput")
.addEventListener("input", function(){

applyFilters();

});

/* =====================
FILTERS
===================== */

document
.querySelectorAll(".filter-btn")
.forEach(btn=>{

btn.addEventListener("click",()=>{

document
.querySelectorAll(".filter-btn")
.forEach(b=>b.classList.remove("active"));

btn.classList.add("active");

currentFilter =
btn.dataset.filter;

applyFilters();

});

});

function applyFilters(){

const search =
document
.getElementById("searchInput")
.value
.toLowerCase();

let filtered =
allJobs.filter(job=>{

const text =
JSON.stringify(job)
.toLowerCase();

const matchesSearch =
text.includes(search);

if(currentFilter === "all")
return matchesSearch;

const employment =
(job["Employment Type"] || "")
.toLowerCase();

const model =
(job["Work Location Model"] || "")
.toLowerCase();

return matchesSearch &&
(
employment.includes(currentFilter.toLowerCase())
||
model.includes(currentFilter.toLowerCase())
);

});

renderJobs(filtered);

}

/* =====================
START
===================== */

loadJobs();

</script>

</body>
</html>
